# Copy to deploy.config — one file per checkout (ArionAgentDev vs ArionAgentProd).
# mode controls ports only. Agent features (including semantic_search) match dev on both.
#
#   mode=dev  -> backend 8920, frontend 5174
#   mode=prod -> backend 8921, frontend 5175
#
# DEPLOY_ROOT is always this checkout directory; do not set it in .env.

mode=dev

# Optional port overrides (defaults come from mode above):
# backend_port=8920
# frontend_port=5174
